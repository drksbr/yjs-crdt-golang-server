# =============================================================================
# DontPad - Variáveis de ambiente
# =============================================================================

# Frontend Next.js
PORT=3000

# Backend Go acessado pelo proxy /api/* do Next
DONTPAD_BACKEND_URL=http://backend:8080

# Backend Go
DATABASE_URL=postgres://USER@postgres:5432/dontpadbr3
DONTPAD_ADDR=:8080
DONTPAD_SCHEMA=dontpadbr3
DONTPAD_NAMESPACE=dontpadbr3
DONTPAD_DATA_DIR=/storage/data
DONTPAD_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Gere em produção com: openssl rand -hex 32
JWT_SECRET=substitua-por-uma-string-aleatoria-segura
# MASTER_PASSWORD=
