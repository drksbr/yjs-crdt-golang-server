# =============================================================================
# DontPad + backend Go (desenvolvimento local)
# =============================================================================

# Frontend Next.js
PORT=3000

# URL do backend Go (usado pelo proxy /api/* no Next)
DONTPAD_BACKEND_URL=http://127.0.0.1:8080

# Backend Go
DATABASE_URL=postgres://postgres@127.0.0.1:5432/dontpadbr3
DONTPAD_ADDR=:8080
DONTPAD_SCHEMA=dontpadbr3
DONTPAD_NAMESPACE=dontpadbr3
DONTPAD_DATA_DIR=storage/data
DONTPAD_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
JWT_SECRET=replace-with-local-random-value
# MASTER_PASSWORD=
